---
const emailInputId = `newsletter-email-${Math.random().toString(36).slice(2, 10)}`;
---

<section
  class="not-prose mt-10 border-t border-border pt-8"
  data-newsletter-form
>
  <div class="max-w-app">
    <h2 class="text-2xl font-semibold text-accent">
      New posts straight to your inbox.
    </h2>
    <p class="mt-2 text-sm text-muted">2× per month. No spam.</p>

    <form class="mt-6 flex flex-col gap-3 sm:flex-row" novalidate>
      <label class="sr-only" for={emailInputId}>Email address</label>
      <input
        id={emailInputId}
        name="email"
        type="email"
        autocomplete="email"
        required
        placeholder="Email address"
        class="w-full flex-1 rounded-md border border-border bg-background px-4 py-3 text-foreground placeholder:text-muted"
      />
      <button
        type="submit"
        class="w-full rounded-md bg-accent px-5 py-3 font-medium text-background transition-opacity hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-70 sm:w-auto"
        data-newsletter-submit
      >
        <span data-newsletter-button-label>Subscribe</span>
      </button>
    </form>

    <p
      class="mt-3 min-h-[1.25rem] text-sm text-muted"
      aria-live="polite"
      data-newsletter-status
      role="status"
    ></p>
  </div>
</section>

<script is:inline data-astro-rerun>
  function setupNewsletterForms() {
    const newsletterForms = document.querySelectorAll("[data-newsletter-form]");

    for (const container of newsletterForms) {
      if (!(container instanceof HTMLElement) || container.dataset.bound === "true")
        continue;

      const form = container.querySelector("form");
      const emailInput = container.querySelector("input[name='email']");
      const submitButton = container.querySelector("[data-newsletter-submit]");
      const buttonLabel = container.querySelector("[data-newsletter-button-label]");
      const status = container.querySelector("[data-newsletter-status]");

      if (
        !(form instanceof HTMLFormElement) ||
        !(emailInput instanceof HTMLInputElement) ||
        !(submitButton instanceof HTMLButtonElement) ||
        !(buttonLabel instanceof HTMLElement) ||
        !(status instanceof HTMLElement)
      ) {
        continue;
      }

      container.dataset.bound = "true";

      const resetStatus = () => {
        status.textContent = "";
        status.classList.remove("text-accent", "text-red-600", "dark:text-red-400");
        status.classList.add("text-muted");
      };

      const setStatus = (message, type) => {
        status.textContent = message;
        status.classList.remove("text-muted", "text-accent", "text-red-600", "dark:text-red-400");

        if (type === "success") {
          status.classList.add("text-accent");
          return;
        }

        if (type === "error") {
          status.classList.add("text-red-600", "dark:text-red-400");
          return;
        }

        status.classList.add("text-muted");
      };

      form.addEventListener("submit", async event => {
        event.preventDefault();

        if (!form.reportValidity()) {
          return;
        }

        resetStatus();
        submitButton.disabled = true;
        buttonLabel.textContent = "Subscribing...";

        try {
          const response = await fetch(
            "https://buttondown.email/api/emails/embed-subscribe/andykrchnk",
            {
              method: "POST",
              headers: {
                "Content-Type": "application/x-www-form-urlencoded",
              },
              body: new URLSearchParams({
                email: emailInput.value.trim(),
              }).toString(),
            }
          );

          if (!response.ok) {
            throw new Error(`Buttondown request failed: ${response.status}`);
          }

          form.reset();
          setStatus("You're in. Check your inbox to confirm.", "success");
        } catch {
          setStatus("Something went wrong. Try again.", "error");
        } finally {
          submitButton.disabled = false;
          buttonLabel.textContent = "Subscribe";
        }
      });
    }
  }

  setupNewsletterForms();
  document.addEventListener("astro:after-swap", setupNewsletterForms);
</script>
